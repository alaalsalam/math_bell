   "options": "practice\nbell_session",
   "reqd": 1
  },
  {
   "fieldname": "grade",
   "fieldtype": "Link",
   "options": "MB Grade",
   "label": "Grade",
   "reqd": 1
  },
  {
   "fieldname": "domain",
   "fieldtype": "Link",
   "options": "MB Domain",
   "label": "Domain",
   "reqd": 1
  },
  {
   "fieldname": "skill",
   "fieldtype": "Link",
   "options": "MB Skill",
   "label": "Skill"
  },
  {
   "fieldname": "student",
