   "options": "MB Student Profile",
   "label": "Student"
  },
  {
   "fieldname": "started_at",
   "fieldtype": "Datetime",
   "label": "Started At"
  },
  {
   "fieldname": "ended_at",
   "fieldtype": "Datetime",
   "label": "Ended At"
  },
  {
   "fieldname": "duration_seconds",
